# Warehouse Planner bridge — configuration
# Copy to `.env` and load it (e.g. `node --env-file=.env server.js` on Node 20+).

# HTTP
PORT=8710
# Origin allowed to call the bridge from a browser. Use the planner's exact origin
# in production instead of "*", e.g. http://192.168.1.20:5173
CORS_ORIGIN=*

# Subiekt GT SQL Server (use a READ-ONLY login)
DB_SERVER=localhost\\INSERTGT
DB_USER=planner_ro
DB_PASSWORD=change-me
DB_DATABASE=Firma

# Which Subiekt column holds the warehouse address (A01-02-03).
# One of: tw_Pole1 .. tw_Pole8, or tw_Uwagi
LOCATION_FIELD=tw_Pole1

# Which warehouse (magazyn) id to report stock for.
MAGAZYN_ID=1
